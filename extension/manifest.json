{
    "manifest_version":  3,
    "name":  "Tabs Manager Pro",
    "version":  "1.0.0",
    "description":  "Backup, merge, manage browser tabs and worklogs as a local knowledge OS.",
    "permissions":  [
                        "tabs",
                        "downloads"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "action":  {
                   "default_title":  "TabOS",
                   "default_popup":  "popup.html"
               },
    "background":  {
                       "service_worker":  "background.js"
                   }
}